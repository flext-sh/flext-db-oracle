            return r[m.ConfigMap].fail(f"Unknown operation: {operation}")
        except (
            t.DbOracle.OracleDatabaseError,
            t.DbOracle.OracleInterfaceError,
            ConnectionError,
        ) as e:
            return r[m.ConfigMap].fail(f"Operation failed: {e}")

    def _execute_with_chain(
